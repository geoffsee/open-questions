{
	"compilerOptions": {
		"strict": true,
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "Bundler",
		"lib": ["ESNext"],
		"types": ["bun", "@cloudflare/workers-types"],
		"noEmit": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"verbatimModuleSyntax": false
	},
	"include": ["src/**/*.ts"],
	"exclude": ["dist", "node_modules"]
}
